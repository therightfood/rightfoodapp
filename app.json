{
  "expo": {
    "name": "Right Food",
    "slug": "right-food",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-jyn.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-jyn.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.placeholder.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Right Food needs camera access to photograph your meals.",
        "NSPhotoLibraryUsageDescription": "Right Food needs photo library access to select meal photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-jyn.png",
        "backgroundColor": "#000000"
      },
      "package": "com.placeholder.app",
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES"]
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      ["expo-camera", { "cameraPermission": "Right Food needs camera access to photograph your meals." }]
    ],
    "scheme": "nutriport",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://3pqctptn272ematfhedrjv4we23tdyxd.app.specular.dev"
    }
  }
}
