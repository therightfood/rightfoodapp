{
  "expo": {
    "name": "Right Food",
    "slug": "right-food",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-jyn.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-jyn.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rightfood.app",
      "appleTeamId": "4G3TGPL24H",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Right Food needs camera access to photograph your meals.",
        "NSPhotoLibraryUsageDescription": "Right Food needs photo library access to select meal photos.",
        "NSUserNotificationUsageDescription": "Right Food sends meal reminder notifications to help you track your portions.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": [
          "group.com.rightfood.app.onesignal"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-jyn.png",
        "backgroundColor": "#000000"
      },
      "package": "com.rightfood.app",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Right Food needs camera access to photograph your meals."
        }
      ]
    ],
    "scheme": "rightfood",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "bfc969c4-0e95-4db9-abfb-93b3ddbb2bd0",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.rightfood.app.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.rightfood.app.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        }
      },
      "router": {},
      "backendUrl": "https://pmqb5ex8jduktbk9hrnr9rfqmaped4be.app.specular.dev",
      "oneSignalAppId": "af4b7d19-9b67-46de-a26d-76ec3c380840"
    }
  }
}