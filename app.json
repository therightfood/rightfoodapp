{
  "expo": {
    "name": "Right Food",
    "slug": "right-food",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-jyn.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-jyn.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
  "bundleIdentifier": "com.rightfood.app",
  "appleTeamId": "4G3TGPL24H",
  "supportsTablet": false,
  "infoPlist": {
    "UIBackgroundModes": ["remote-notification"]
  },
  "entitlements": {
    "aps-environment": "production",
    "com.apple.security.application-groups": [
      "group.com.rightfood.app.onesignal"
    ]
  }
},
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-jyn.png",
        "backgroundColor": "#000000"
      },
      "package": "com.placeholder.app",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
  [
    "onesignal-expo-plugin",
    {
      "mode": "production",
      "iPhoneDeploymentTarget": "15.1"
    }
  ]
],
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Right Food needs camera access to photograph your meals."
        }
      ]
    ],
    "scheme": "rightfood",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://3pqctptn272ematfhedrjv4we23tdyxd.app.specular.dev",
      "oneSignalAppId": "af4b7d19-9b67-46de-a26d-76ec3c380840"
    }
  }
}
